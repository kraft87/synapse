# Synapse configuration. Copy to .env and fill in. See ARCHITECTURE.md §13 for the full list.

# --- Required ---
# Password for the bundled Postgres. Compose passes it to the postgres service
# as POSTGRES_PASSWORD (applied at first initdb only) — it MUST match the
# password embedded in SYNAPSE_DB_URL below; change both together.
SYNAPSE_DB_PASSWORD=CHANGEME
# Postgres DSN (psycopg3-style) the app services connect with. Host `postgres`
# is the compose service name (right for the bundled stack); use
# `localhost:5432` instead when running scripts on the host. The password must
# equal SYNAPSE_DB_PASSWORD above.
SYNAPSE_DB_URL=postgresql://synapse:CHANGEME@postgres:5432/synapse
# Voyage AI key (embeddings + rerank — the default backend; can stay blank if
# you configure the alternative embedding/rerank backends below).
VOYAGE_API_KEY=
# Auth for the extraction LLM (the Claude Code CLI baked into the image).
# Either variable works; if both are set, the subscription token wins:
#   CLAUDE_CODE_OAUTH_TOKEN — Claude Pro/Max subscription OAuth token
#                             (`claude setup-token`); no per-token billing.
#   ANTHROPIC_API_KEY       — pay-per-token API key from console.anthropic.com.
CLAUDE_CODE_OAUTH_TOKEN=
# ANTHROPIC_API_KEY=

# --- Extraction LLM (optional) ---
# Backend for the extraction LLM: claude-code (default; Agent SDK via the token
# above) or openai (any OpenAI-compatible /chat/completions endpoint — OpenRouter,
# Ollama, vLLM). Extraction quality is tuned and validated on Claude Haiku; other
# models are unvalidated.
SYNAPSE_LLM_PROVIDER=claude-code
# Only used when SYNAPSE_LLM_PROVIDER=openai:
SYNAPSE_LLM_BASE_URL=https://openrouter.ai/api/v1
SYNAPSE_LLM_API_KEY=
# Single-model mode: this id overrides all per-call Claude model names.
SYNAPSE_LLM_MODEL=anthropic/claude-haiku-4.5

# --- Embeddings + rerank (optional) ---
# Embedding backend: voyage (default; uses VOYAGE_API_KEY above) or openai (any
# OpenAI-compatible POST /embeddings endpoint — OpenAI, Ollama, TEI, Infinity, vLLM).
# IMPORTANT: the embedding width is fixed at the database's FIRST BOOT (the schema's
# vector/halfvec columns are provisioned at SYNAPSE_EMBED_DIMS, default 2048). To run
# a non-2048-dim model, set SYNAPSE_EMBED_DIMS before the first `docker compose up`;
# an existing database keeps the dims+model it was provisioned with (recorded in
# synapse_meta) and the server fails loudly on a mismatch.
#SYNAPSE_EMBED_PROVIDER=voyage
#SYNAPSE_EMBED_BASE_URL=
#SYNAPSE_EMBED_API_KEY=
#SYNAPSE_EMBED_MODEL=
#SYNAPSE_EMBED_DIMS=2048
# Rerank backend: voyage (default) | http (TEI/Infinity/Cohere-compatible POST /rerank)
# | none (no rerank calls — recall serves the pre-rerank RRF fusion order; retrieval
# quality drops: the cross-encoder rerank leg is the active ingredient).
#SYNAPSE_RERANK_PROVIDER=voyage
#SYNAPSE_RERANK_BASE_URL=
#SYNAPSE_RERANK_API_KEY=
# For voyage this picks the Voyage cross-encoder (default rerank-2.5-lite);
# for http it's the served model id (required when the server hosts several).
#SYNAPSE_RERANK_MODEL=

# Fully local, zero-signup recipe (the bundled `local-inference` compose profile):
#   docker compose --profile local-inference up -d
# then set (BEFORE the database's first boot — see the dims note above):
#   SYNAPSE_EMBED_PROVIDER=openai
#   SYNAPSE_EMBED_BASE_URL=http://local-inference:7997
#   SYNAPSE_EMBED_MODEL=BAAI/bge-base-en-v1.5
#   SYNAPSE_EMBED_DIMS=768
#   SYNAPSE_RERANK_PROVIDER=http
#   SYNAPSE_RERANK_BASE_URL=http://local-inference:7997
#   SYNAPSE_RERANK_MODEL=BAAI/bge-reranker-base
# VOYAGE_API_KEY can then stay blank. Honest caveat: published retrieval quality
# was measured on the Voyage stack; the local models are a convenience floor.

# --- Common optional ---
# MCP streamable-HTTP / ingest port. Sets BOTH the server's listener and the
# compose-published host port, so changing it here is all you need when 8765
# is taken on your host.
MCP_PORT=8765
# Host port the bundled Postgres is published on (containers reach it via the
# service name regardless). Change when 5432 is taken on your host.
POSTGRES_HOST_PORT=5432
# Stop-hook transcript tail size, in raw records.
SYNAPSE_INGEST_TAIL=400
# Poller full-cycle cadence, seconds.
POLL_INTERVAL_SECONDS=300
# Telemetry emit only; leave blank to disable.
LOGFIRE_TOKEN=

# --- Auth (leave the machine token blank to run the server fully open, e.g. local-only) ---
# Shared bearer the plugin hooks send to /ingest, /recall, and /mcp.
SYNAPSE_MACHINE_TOKEN=
# Public base URL of this instance (used for OAuth callbacks).
SYNAPSE_PUBLIC_URL=https://synapse.example.net
# GitHub OAuth app, for the claude.ai web connector and `/synapse:login`.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Comma-separated GitHub logins allowed to authenticate (fail-closed if OAuth is on and this is empty).
ALLOWED_GITHUB_USERS=
# Signing key for issued OAuth tokens; generate a random value.
SYNAPSE_OAUTH_SIGNING_KEY=
